# Realpolitik Ecosystem Database Connections
DATABASE_URL=postgresql://user:password@localhost:5432/realpolitik
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
QDRANT_URI=http://localhost:6333
REDIS_URL=redis://localhost:6379

# Message Queue (RabbitMQ via Iris)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# AI Service
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cassandra Processing Configuration
CASSANDRA_MAX_CONCURRENT=5
ANALYSIS_TIMEOUT_SECONDS=120
MODEL_ENRICHMENT=anthropic/claude-3-haiku
MODEL_SYNTHESIS=anthropic/claude-3-sonnet

# Caching
ANALYSIS_CACHE_TTL_HOURS=24
MAX_CACHE_SIZE_MB=500

# Queue Settings
RABBITMQ_QUEUE=analysis.requested
RABBITMQ_PREFETCH_COUNT=10
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=30

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=8080